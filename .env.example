# Environment Configuration
HEADLESS=true
BROWSER_TIMEOUT=30000
SCREENSHOT_ON_FAILURE=true

# API Keys (add your own)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GROQ_API_KEY=gsk-...

# Testing
MAX_RETRIES=3
RETRY_DELAY=2
TEST_TIMEOUT=60

# Logging
LOG_LEVEL=INFO
ENABLE_SENTRY=false
# SENTRY_DSN=https://...

# Dashboard
DASHBOARD_PORT=8501
API_PORT=8000

# Application
DEBUG=false
